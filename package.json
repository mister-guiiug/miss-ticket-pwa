{
  "name": "miss-ticket-pwa",
  "version": "1.0.0",
  "description": "Interface PWA pour Miss Ticket - Contrôle à distance de l'application desktop",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:rules": "firebase deploy --only firestore:rules",
    "firebase:indexes": "firebase deploy --only firestore:indexes"
  },
  "dependencies": {
    "firebase": "^12.12.0",
    "lucide-react": "^1.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-reader": "^3.0.0-beta-1"
  },
  "devDependencies": {
    "@mister-guiiug/dev-wpa-config": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.0"
  }
}
